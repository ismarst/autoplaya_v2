# Forzar que todos los archivos de texto se normalicen a LF al hacer commit
* text=auto eol=lf

# Asegurar que archivos específicos siempre sean LF
*.js text eol=lf
*.php text eol=lf
*.html text eol=lf
*.env text eol=lf
.gitignore text eol=lf

# Los binarios (imágenes) no se tocan
*.png binary
*.jpg binary